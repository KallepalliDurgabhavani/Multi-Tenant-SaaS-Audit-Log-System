# Kafka
KAFKA_BROKERS=kafka:9093
KAFKA_INTERNAL_BROKER=kafka:9092
KAFKA_SASL_BROKER=kafka:9093
KAFKA_CLIENT_MECHANISM=SCRAM-SHA-256

# Tenant credentials (used by provisioning, gateway, and tests)
TENANT_ACME_PASSWORD=change-me-acme
TENANT_GLOBEX_PASSWORD=change-me-globex
TENANT_INITECH_PASSWORD=change-me-initech
GATEWAY_PASSWORD=change-me-gateway
ARCHIVER_PASSWORD=change-me-archiver

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=kafka-archive

# App
APP_PORT=8080
ARCHIVE_MIN_AGE_MS=300000
ARCHIVER_CONSUMER_GROUP=archive-worker-v1
